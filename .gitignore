# Kōan instance data (private to each user)
instance
.koan*
.claude/*
!.claude/settings.json
!.claude/skills
.claude/skills/*
!.claude/skills/brain

# /brain ingest acquisition scratch — snapshots only, never committed
raw/*
!raw/articles
!raw/notes
!raw/files
raw/articles/*
raw/notes/*
raw/files/*
!raw/articles/.gitkeep
!raw/notes/.gitkeep
!raw/files/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.coverage
.coverage.*
htmlcov/
koan/htmlcov/

# Runtime
.koan-status
.koan-stop
.koan-project
.koan-quota-reset
.ssh-agent-sock

# Environment & secrets
.env
.envrc
.zai.key

# OS
.DS_Store

# IDE
.vscode/
.idea/
wiki/.obsidian/
.last-review-sha
projects.yaml
projects.docker.yaml

# custom skills
# ignore all dirs with the exception of core
/koan/skills/*/
!/koan/skills/core/

# wp-copilot-skills: Ignore symlinked agents (pointing to shared installation)
.github/agents/wp.*
.github/prompts/wp.*

# pytest-split durations (generated locally)
.test_durations

# Process log files (root only, not koan/skills/core/logs/)
/logs/

# Runtime state files
.branch-cleanup-tracker.json
.aider*

# Docker (generated by setup-docker.sh)
docker-compose.override.yml
.env.docker
claude-auth/
.spec/

devcontainer-tmp/
